# tantalus-local configuration

# Primary endpoint (used when LLM_ENDPOINTS is not set)
LLM_ENDPOINT=http://localhost:11450
LLM_MODEL=qwen3.6-35b

# Multiple endpoints (round-robin load balancing)
# LLM_ENDPOINTS=http://localhost:11450,http://localhost:11451

# Server port
PORT=3333

# Optional per-round overrides (set both endpoint+model per round):
# R1_ENDPOINT=http://localhost:11450
# R1_MODEL=qwen3.6-35b
# R2_ENDPOINT=http://localhost:11452
# R2_MODEL=qwen3.6-27b
