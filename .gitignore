.DS_Store

# Imported Tantalus working copy (the agent-under-test; replace AWS→local inference).
# Kept out of this repo's history — it carries Tantalus secrets/private code and is
# the private upstream, not part of the public artifact.
/tantalus/

# Proprietary Tantalus UI + example deployment configs. Not needed for
# experiment reproducibility — the /eval harness and `cargo build` do not
# reference these. (NB: src/main.rs include_str!'s templates/ + static/ at
# compile time, so those stay tracked; only the standalone UI / compose
# bundles are excluded here.)
/ui_portable/
/example_compose/

# Agent working files (memory bank, rules, plans, skills). Not part of the
# public artifact; untracked so the repo isn't carrying session state.
/.claude/
